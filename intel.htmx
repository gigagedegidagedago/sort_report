<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>氣泡排序視覺演示</title>
  <style>
    body {
      background: #f4f4f4;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    canvas {
      background: #fff;
      border: 1px solid #ccc;
    }
  </style>
</head>
<body>
  <canvas id="canvas" width="600" height="400"></canvas>
  <script>
    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d");

    let data = [50, 120, 80, 30, 200, 90, 60];
    let steps = [];

    // 記錄排序過程
    function bubbleSort(arr) {
      let n = arr.length;
      let tempArr = arr.slice();
      for (let i = 0; i < n; i++) {
        for (let j = 0; j < n - i - 1; j++) {
          steps.push(tempArr.slice());
          if (tempArr[j] > tempArr[j + 1]) {
            [tempArr[j], tempArr[j + 1]] = [tempArr[j + 1], tempArr[j]];
            steps.push(tempArr.slice());
          }
        }
      }
      steps.push(tempArr.slice());
    }

    bubbleSort(data);

    // 畫柱狀圖
    function drawBars(arr) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const barWidth = canvas.width / arr.length;
      arr.forEach((val, i) => {
        ctx.fillStyle = "#3498db";
        ctx.fillRect(i * barWidth, canvas.height - val, barWidth - 5, val);
      });
    }

    // 動畫播放
    let frame = 0;
    function animate() {
      drawBars(steps[frame]);
      frame++;
      if (frame < steps.length) {
        setTimeout(animate, 500);
      }
    }

    animate();
  </script>
</body>
</html>
